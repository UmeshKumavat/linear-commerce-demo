export function expressionFromScroll(progress: number): LinxoExpression {
  if (progress < 0.12) return "neutral";
  if (progress < 0.32) return "happy";
  if (progress < 0.52) return "focused";
  if (progress < 0.72) return "thinking";
  return "excited";
}
